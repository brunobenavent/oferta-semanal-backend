# Server
PORT=3000
NODE_ENV=development

# MongoDB — obligatorio: debe ser una URI de Atlas cloud
# Ej: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<database>
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/oferta-semanal?retryWrites=true&w=majority

# Dantia API (Sage ERP)
THIRD_PARTY_API_URL=https://dantia-api-url.com
THIRD_PARTY_USERNAME=your-username
THIRD_PARTY_PASSWORD=your-password

# Cloudinary (misma cuenta que la fototeca)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# FTP externo (imágenes de artículos)
FTP_HOST=your-ftp-host.com
FTP_PORT=21
FTP_USER=your-ftp-user
FTP_PASSWORD=your-ftp-password
FTP_PATH=/images

# Sync intervals (en milisegundos)
SYNC_OFFER_INTERVAL=600000    # 10 minutos
SYNC_IMAGE_INTERVAL=30000     # 30 segundos

# JWT (autenticación)
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=24h

# Frontend URL (para enlaces en emails)
FRONTEND_URL=http://localhost:5173

# Superadmin inicial
SUPERADMIN_EMAIL=comunicacion@viverosguzman.es
SUPERADMIN_PASSWORD=+vpemq880Vbbc

# Email SMTP (Gmail) — necesario para verificación de email
# EMAIL_USER=tu-email@gmail.com
# EMAIL_PASS=tu-contraseña-de-aplicacion
# EMAIL_FROM=Oferta Semanal <noreply@viverosguzman.es>

# Excepciones de dominio (emails permitidos fuera de @viverosguzman.es, separados por coma)
# ALLOWED_EMAILS=admin@otro-dominio.com
